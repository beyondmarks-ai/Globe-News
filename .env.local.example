# Mapbox: create a free account at https://account.mapbox.com/
# Create an access token (default public token is fine for client-side).
# Paste it below so the map can load the dark base style.

NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your_mapbox_public_access_token_here

# Gemini (AI summaries for popup): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Firecrawl (scraping): https://firecrawl.dev
FIRECRAWL_API_KEY=fc-your-api-key-here

# Cron / Cloud Scheduler: secret query param to protect /api/gdelt (use a strong random value)
CRON_SECRET=super-secret-key-2026
